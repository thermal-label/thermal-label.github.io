{
  "name": "thermal-label.github.io",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "verify-suite-config": "node scripts/verify-suite-config.mjs",
    "docs:pull": "node scripts/pull-driver-docs.mjs",
    "docs:hardware": "node scripts/build-hardware-page.mjs",
    "docs:catalog": "node scripts/build-catalog-tables.mjs",
    "docs:media": "node scripts/build-media-pages.mjs",
    "docs:connecting": "node scripts/build-connecting-page.mjs",
    "docs:matrix": "node scripts/build-matrix-page.mjs",
    "docs:prep": "npm run verify-suite-config && npm run docs:pull && npm run docs:hardware && npm run docs:catalog && npm run docs:media && npm run docs:connecting && npm run docs:matrix",
    "docs:dev": "npm run docs:prep && vitepress dev docs",
    "docs:build": "npm run docs:prep && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@mbtech-nl/bitmap": "^1.2.0",
    "@thermal-label/brother-ql-core": "file:../brother-ql/packages/core",
    "@thermal-label/brother-ql-web": "file:../brother-ql/packages/web",
    "@thermal-label/contracts": "^0.6.0",
    "@thermal-label/d1-core": "^0.6.0",
    "@thermal-label/labelmanager-core": "file:../labelmanager/packages/core",
    "@thermal-label/labelmanager-web": "file:../labelmanager/packages/web",
    "@thermal-label/labelwriter-core": "file:../labelwriter/packages/core",
    "@thermal-label/labelwriter-web": "file:../labelwriter/packages/web",
    "@thermal-label/letratag-core": "file:../letratag/packages/core",
    "@thermal-label/transport": "^0.6.0"
  },
  "devDependencies": {
    "vitepress": "^1.6.3"
  },
  "overrides": {
    "@thermal-label/brother-ql-core": "$@thermal-label/brother-ql-core",
    "@thermal-label/brother-ql-web": "$@thermal-label/brother-ql-web",
    "@thermal-label/contracts": "$@thermal-label/contracts",
    "@thermal-label/d1-core": "$@thermal-label/d1-core",
    "@thermal-label/labelmanager-core": "$@thermal-label/labelmanager-core",
    "@thermal-label/labelmanager-web": "$@thermal-label/labelmanager-web",
    "@thermal-label/labelwriter-core": "$@thermal-label/labelwriter-core",
    "@thermal-label/labelwriter-web": "$@thermal-label/labelwriter-web",
    "@thermal-label/letratag-core": "$@thermal-label/letratag-core",
    "@thermal-label/transport": "$@thermal-label/transport"
  }
}
