{
  "name": "thermal-label.github.io",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "verify-suite-config": "node scripts/verify-suite-config.mjs",
    "docs:pull": "node scripts/pull-driver-docs.mjs",
    "docs:hardware": "node scripts/build-hardware-page.mjs",
    "docs:catalog": "node scripts/build-catalog-tables.mjs",
    "docs:media": "node scripts/build-media-pages.mjs",
    "docs:connecting": "node scripts/build-connecting-page.mjs",
    "docs:matrix": "node scripts/build-matrix-page.mjs",
    "docs:harness": "node scripts/pull-harness-bundles.mjs",
    "docs:prep": "npm run verify-suite-config && npm run docs:pull && npm run docs:hardware && npm run docs:catalog && npm run docs:media && npm run docs:connecting && npm run docs:matrix && npm run docs:harness",
    "docs:dev": "npm run docs:prep && vitepress dev docs",
    "docs:build": "npm run docs:prep && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@mbtech-nl/bitmap": "^1.2.0",
    "@thermal-label/brother-ql-core": "^0.6.0",
    "@thermal-label/brother-ql-web": "^0.6.0",
    "@thermal-label/contracts": "^0.6.0",
    "@thermal-label/d1-core": "^0.6.0",
    "@thermal-label/labelmanager-core": "^0.6.0",
    "@thermal-label/labelmanager-web": "^0.6.0",
    "@thermal-label/labelwriter-core": "^0.6.0",
    "@thermal-label/labelwriter-web": "^0.6.0",
    "@thermal-label/letratag-core": "^0.6.0",
    "@thermal-label/transport": "^0.6.0"
  },
  "devDependencies": {
    "vitepress": "^1.6.3"
  }
}
