node_modules
docs/.vitepress/dist
docs/.vitepress/cache
.staging
.aggregate
.DS_Store
.claude/

# Pulled at build time by scripts/pull-driver-docs.mjs from sibling repos.
# Tracked content lives in those repos' docs/ folders.
docs/contracts/
docs/transport/
docs/d1-core/
docs/brother-ql/
docs/cat-printer/
docs/labelife/
docs/labelmanager/
docs/labelwriter/
docs/letratag/
docs/marklife/
docs/niimbot/
docs/cli/

# `docs/public/` itself is build-relocated content (pull-driver-docs.mjs
# moves each driver's public/ tree under docs/public/<driver>/;
# pull-harness-bundles.mjs drops each harness app's released bundle under
# docs/public/harness/<driver>/). Hand-authored static assets live under
# docs/public/icons/ and must be tracked, so we ignore the directory
# contents but un-ignore the icons subtree explicitly.
docs/public/*
!docs/public/icons
!docs/public/icons/**
!docs/public/robots.txt

# Generated at build time by scripts/build-hardware-page.mjs +
# scripts/build-matrix-page.mjs. The wishlist is hand-authored so it's
# un-ignored explicitly. Note: the parent must be ignored as `*` rather
# than as a directory to allow the negation to take effect on a child.
docs/hardware/*
!docs/hardware/wishlist.md

# Generated at build time by scripts/build-connecting-page.mjs.
docs/connecting.md
